class Solution {
    public ListNode middleNode(ListNode head) {   //finding middle element(two pass solution-not so good)
        ListNode temp = head;
        int len = 0;
        while(temp != null){
            temp = temp.next;
            len++;

        }
        int mid = len/2 + 1;
        temp = head;
        for(int i = 0; i<mid-1;i++){
            temp = temp.next;
        }
        return temp;
    }
}
