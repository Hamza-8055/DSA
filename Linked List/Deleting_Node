
class Solution {        //deleting nth node from last(len-n+1)th node from start(basic method)
    public ListNode removeNthFromEnd(ListNode head, int n) {
        ListNode temp = head;
        int len = 0;
        while(temp != null){
            temp = temp.next;
            len++;
        }

        if(len==n){
            head = head.next;
            return head;
        }
        temp = head;
        for(int i = 1; i<=len-n-1;i++){             //loop will run only len-n-1 times
            temp = temp.next;

        }
        temp.next = temp.next.next;
        return head;
    }
}

class Solution {        //deleting nth node from last(len-n+1)th node from start(slow/fast method)
    public ListNode removeNthFromEnd(ListNode head, int n) {
        ListNode slow = head;
        ListNode fast = head;
        for(int i = 1; i<=n;i++){
            fast = fast.next;
        }
        if(fast==null){
            return head.next;
        }
        while(fast.next != null){
            slow = slow.next;
            fast = fast.next;
        }
        slow.next = slow.next.next;
        return head;


    }
}
