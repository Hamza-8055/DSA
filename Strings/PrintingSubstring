import java.util.*;         //printing substring of a string
public class Main{
    public static void Substrings(String s){
        int n = s.length();
        for(int i = 0;i<n;i++){
            int start = i;

            for(int j = i+1;j<=n;j++){
                int end = j;

                System.out.print(s.substring(start,end)+" ");
            }
        }
        System.out.println();

    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter the string: ");
        String s = sc.nextLine();
        Substrings(s);
    }
}
